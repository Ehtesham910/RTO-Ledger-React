generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:rto_ledger_system123@ep-still-sea-ao7ukut5-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model customers {
  id               BigInt             @id @default(autoincrement())
  customer_code    String             @unique @db.VarChar(20)
  name             String             @db.VarChar(100)
  mobile           String             @unique(map: "unique_mobile") @db.VarChar(15)
  email            String?            @unique(map: "unique_email") @db.VarChar(100)
  address          String?
  created_by       BigInt?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  is_active        Boolean?           @default(true)
  password         String?            @db.VarChar(255)
  users            users?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_customer_creator")
  ledgers          ledgers[]
  service_requests service_requests[]
  vehicles         vehicles[]
}

model ledgers {
  id                 BigInt            @id @default(autoincrement())
  customer_id        BigInt
  vehicle_id         BigInt?
  service_request_id BigInt?
  service_fee        Decimal           @db.Decimal(12, 2)
  amount_paid        Decimal?          @default(0) @db.Decimal(12, 2)
  due_amount         Decimal?          @default(dbgenerated("(service_fee - amount_paid)")) @db.Decimal(12, 2)
  status             String?           @default("PENDING") @db.VarChar(20)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  customers          customers         @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_customer")
  service_requests   service_requests? @relation(fields: [service_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ledger_service_request")
  vehicles           vehicles?         @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ledger_vehicle")
  receipts           receipts[]
}

model permissions {
  id               BigInt             @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  description      String?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  role_permissions role_permissions[]
  user_permissions user_permissions[]
}

model receipts {
  id                    BigInt    @id @default(autoincrement())
  receipt_no            String    @unique @db.VarChar(30)
  ledger_id             BigInt
  amount_received       Decimal   @db.Decimal(12, 2)
  payment_mode          String    @db.VarChar(20)
  transaction_reference String?   @db.VarChar(100)
  remarks               String?
  received_by           BigInt?
  received_at           DateTime? @default(now()) @db.Timestamp(6)
  ledgers               ledgers   @relation(fields: [ledger_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_receipt_ledger")
  users                 users?    @relation(fields: [received_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_receipt_user")
}

model role_permissions {
  role_id       BigInt
  permission_id BigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_role_permissions_permission")
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_role_permissions_role")

  @@id([role_id, permission_id])
}

model roles {
  id               BigInt             @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  description      String?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  role_permissions role_permissions[]
  users            users[]
}

model service_requests {
  id           BigInt    @id @default(autoincrement())
  request_no   String    @unique @db.VarChar(30)
  customer_id  BigInt
  vehicle_id   BigInt
  service_id   BigInt
  amount       Decimal   @db.Decimal(12, 2)
  status       String?   @default("Pending") @db.VarChar(20)
  remarks      String?
  created_by   BigInt?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)
  ledgers      ledgers[]
  users        users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_sr_creator")
  customers    customers @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_sr_customer")
  services     services  @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_sr_service")
  vehicles     vehicles  @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_sr_vehicle")
}

model services {
  id               BigInt             @id @default(autoincrement())
  service_name     String             @db.VarChar(100)
  default_fee      Decimal?           @db.Decimal(12, 2)
  description      String?
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  service_requests service_requests[]
}

model user_permissions {
  user_id       BigInt
  permission_id BigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, permission_id])
}

model users {
  id               BigInt             @id @default(autoincrement())
  username         String             @unique @db.VarChar(100)
  email            String?            @unique @db.VarChar(255)
  password_hash    String
  role_id          BigInt
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  customers        customers[]
  receipts         receipts[]
  service_requests service_requests[]
  user_permissions user_permissions[]
  roles            roles              @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_role")
}

model vehicles {
  id                BigInt             @id @default(autoincrement())
  customer_id       BigInt
  vehicle_number    String             @unique @db.VarChar(20)
  vehicle_type      String?            @db.VarChar(50)
  chassis_number    String?            @db.VarChar(100)
  engine_number     String?            @db.VarChar(100)
  registration_date DateTime?          @db.Date
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  is_active         Boolean?           @default(true)
  driver_name       String?            @db.VarChar(100)
  driver_mobile     String?            @db.VarChar(15)
  ledgers           ledgers[]
  service_requests  service_requests[]
  customers         customers          @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vehicle_customer")
}
